              <script language="4">
                <content>
                  <![CDATA[class MyClass(GeneratedClass):
    def __init__(self):
        GeneratedClass.__init__(self)

        import os

        self.music_dir = "/home/nao/music"

        if not os.path.exists(self.music_dir):
            self.logger.info("Path does not exist")
            return

        if not os.path.isdir(self.music_dir):
            self.logger.info("Path is not directory")
            return

    def onLoad(self):
        #put initialization code here
        pass

    def onUnload(self):
        #put clean-up code here
        self.onStopped() #activate the output of the box

    def onInput_onStart(self):

        import os

        audio = ALProxy("ALAudioPlayer")

        for file in os.listdir(self.music_dir):
            #self.logger.info(file)
            path = self.music_dir + "/" + file
#            audio.playFile(path)
            self.logger.info(type(path))
        path = self.music_dir + '/' + 'down_under__men_at_work.mp3'
        self.logger.info(type(path))
        audio.playFile(path)
        self.onInput_onStop()

    def onInput_onStop(self):
        self.onUnload() #it is recommended to reuse the clean-up as the box is stopped]]>
